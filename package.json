{
  "name": "zai-agent-audited-compute",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node tools/dev.js",
    "dev:api": "node apps/api/src/server.js",
    "dev:fancy": "npm --prefix apps/compute-outsourcing-platform run dev",
    "check": "node --check apps/api/src/server.js && node --check tools/dev.js && node --check scripts/deploy-sepolia.cjs",
    "contracts:compile": "hardhat compile",
    "contracts:test": "hardhat test",
    "contracts:deploy:sepolia": "hardhat run scripts/deploy-sepolia.cjs --network sepolia"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "hardhat": "^2.22.19"
  }
}
