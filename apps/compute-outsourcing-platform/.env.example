# ZAI_API_KEY: Optional for local demos. When present, the local API bridge
# calls the official Z.AI Chat Completions endpoint. Without it, the frontend
# uses a local mock with the same response shape.
ZAI_API_KEY="MY_ZAI_API_KEY"
ZAI_MODEL="GLM-4.5-Air"
ZAI_API_BASE="https://api.z.ai/api/coding/paas/v4"
API_PORT="8789"
ZAI_TIMEOUT_MS="60000"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
